# Frontend Environment Variables (Vite)
# Rename this file to .env and fill in the values

VITE_API_URL=http://localhost:5001
PORT=5001
VITE_SITE_URL=https://seva-bharat.vercel.app/

# Required: Get these from your Supabase Dashboard: Settings > API
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Required: Get these from your Razorpay Dashboard
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id

# Backend Environment Variables
# These should be set in your hosting platform (e.g. Render)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email Credentials (for receipt emails)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
